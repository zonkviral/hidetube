{
  "short_name": "HideTube",
  "name": "HideTube",
  "description": "Clean up your YouTube experience by toggling player UI elements on demand.",
  "manifest_version": 3,
  "version": "1.2",
  "action": {
    "default_popup": "index.html",
    "default_title": "Toggle YouTube player overlays"
  },

  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },

  "background": {
    "scripts": ["src/extension/background.ts"],
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*", "*://*.youtube-nocookie.com/*"],
      "js": ["src/extension/content.ts"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["src/extension/content.js"],
      "matches": ["*://*.youtube.com/*", "*://*.youtube-nocookie.com/*"]
    }
  ],

  "host_permissions": ["*://*.youtube.com/*", "*://*.youtube-nocookie.com/*"],
  "permissions": ["storage", "activeTab", "scripting", "webNavigation"],
  "browser_specific_settings": {
    "gecko": {
      "id": "hidetube@yourdomain.com"
    }
  }
}
